<div class="hero-stage" aria-label="Kagura Player operation preview">
  <div class="orbital-glow" aria-hidden="true"></div>
  <div class="icon-orbit" aria-hidden="true">
    <img src="/media/generated/kagura-player-icon-512.png" alt="" />
  </div>
  <div class="player-demo">
    <div class="player-top">
      <span>Kagura Player</span>
      <span class="status-live">Ready to clip</span>
    </div>
    <div class="screen">
      <div class="scanline" aria-hidden="true"></div>
      <span class="play-icon" aria-hidden="true"></span>
      <div class="caption-strip">A地点を押す → B地点を押す → そのまま保存</div>
    </div>
    <div class="timeline">
      <div class="timeline-track" aria-hidden="true"><span></span></div>
      <div class="markers">
        <span>A 01:12</span>
        <span>Quick clip</span>
        <span>B 01:48</span>
      </div>
    </div>
  </div>
</div>
