---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, withBase } from "@/data/site";

const faqs = [
  { question: "Can I use YOMUVIA for free?", answer: "Yes. Free costs ¥0 and includes local playback, organization, A-B repeat, quick clipping, and local AI subtitles." },
  { question: "How much is YOMUVIA Pro?", answer: "Pro is ¥1,480 per month or ¥14,800 per year. The seven-day free trial includes 30 cloud minutes." },
  { question: "What happens after I use 600 cloud minutes?", answer: "Pro includes 600 cloud minutes each month. After the quota, you can continue with your own supported API key through BYOK." },
  { question: "Can these terms change before launch?", answer: "These are the current sales terms. If a legal or payment-platform requirement makes a change necessary, the updated terms will be shown before checkout confirmation." },
];
---

<BaseLayout title="Pricing - YOMUVIA" description="YOMUVIA Free is ¥0. Pro is ¥1,480/month or ¥14,800/year, with a seven-day trial, 30 trial cloud minutes, 600 monthly cloud minutes, and BYOK beyond quota." canonicalPath="/en/pricing/" lang="en" breadcrumbTitle="Pricing" faqItems={faqs}>
  <header class="page-hero"><div class="container"><p class="eyebrow">Pricing</p><h1>Free is ¥0.<br />Pro is ¥1,480/month.</h1><p class="lead">Pro is also ¥14,800/year. The seven-day free trial includes 30 cloud minutes; Pro includes 600 cloud minutes each month, with BYOK after the quota.</p></div></header>
  <section class="content-band"><div class="container status-callout"><strong>Pre-launch sales display</strong>Checkout is not active yet. If a legal or payment-platform requirement makes a change necessary, the applicable terms will be shown before purchase confirmation.</div></section>
  <section class="content-band alt"><div class="container plan-grid">
    <article class="plan"><p class="section-kicker">FREE</p><h2>Watch, organize, and clip</h2><p class="price">¥0</p><ul><li>Local playback</li><li>Playlists and favorites</li><li>A-B repeat</li><li>Quick clipping</li><li>Local AI subtitles and cache</li><li>Subtitle edits and correction memory</li><li>Clip library and compatible-media joining</li></ul><a class="button secondary" href={withBase("/en/download/")}>See release status</a></article>
    <article class="plan pro"><p class="section-kicker">PRO</p><h2>Bring subtitles into creation</h2><p class="price">¥1,480 / month<br /><small>¥14,800/year saves two months</small></p><ul><li>Seven-day free trial</li><li>30 cloud minutes during the trial</li><li>600 cloud minutes each month</li><li>BYOK after the 600-minute quota</li><li>Clips with burned-in subtitles</li><li>Cloud context correction and translation</li><li>Signed licensing with offline grace</li></ul><div class="plan-actions">{site.monthlyCheckoutUrl ? <a class="button primary" href={site.monthlyCheckoutUrl}>Try monthly for seven days</a> : <span class="button secondary" aria-disabled="true">Monthly plan coming soon</span>}{site.annualCheckoutUrl ? <a class="button secondary" href={site.annualCheckoutUrl}>Try annual for seven days</a> : <span class="button secondary" aria-disabled="true">Annual plan coming soon</span>}</div></article>
  </div></section>
  <section class="content-band"><div class="container content-grid"><h2>Cloud quota and BYOK</h2><div class="prose"><p>Free local playback, clipping, and local AI subtitles do not use cloud minutes. Pro includes 600 minutes each month for cloud context correction and translation.</p><p>After the included quota, connect your own supported AI provider API key through BYOK. Charges from that provider are billed separately to you by the provider.</p></div></div></section>
  <section class="section faq"><div class="container faq-layout"><div><div class="section-kicker">FAQ</div><h2>Pricing questions</h2></div><div class="faq-list">{faqs.map((item, index) => <details open={index === 0}><summary>{item.question}</summary><p>{item.answer}</p></details>)}</div></div></section>
</BaseLayout>
