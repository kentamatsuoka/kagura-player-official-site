---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Quick Clip - YOMUVIA" description="Save an A-B range from the video you are watching." canonicalPath="/en/features/quick-clip/" lang="en">
  <section class="section">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Quick Clip</p>
        <h1>Save the A-B range you just found.</h1>
        <p class="lead">Set the start, set the end, then save the section without turning the player into a full editor.</p>
      </div>
      <div class="steps">
        <div class="step"><div><strong>Set A</strong><p>Choose the start of the useful moment.</p></div></div>
        <div class="step"><div><strong>Set B</strong><p>Choose the end and review the range.</p></div></div>
        <div class="step"><div><strong>Save</strong><p>Keep watching while the clip is saved.</p></div></div>
      </div>
    </div>
  </section>
</BaseLayout>
