---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site, withBase } from "@/data/site";
---

<BaseLayout title="Download - YOMUVIA" description="Release status, requirements, installation, and safety information for YOMUVIA 0.6.0 Preview on Windows." canonicalPath="/en/download/" lang="en">
  <header class="page-hero"><div class="container"><p class="eyebrow">Windows / 0.6.0 Preview</p><h1>Coming to the<br />Microsoft Store.</h1><p class="lead">The app, Pro licensing, and cloud AI connection have passed integration checks. We are completing the public package and signed update path for a safe Windows release.</p><div class="hero-actions">{site.downloadUrl ? <a class="button primary" href={site.downloadUrl}>Download for Windows</a> : <a class="button primary" href={site.supportUrl}>Get a release notice</a>}<a class="button secondary" href={withBase("/en/changelog/")}>Read the changelog</a></div></div></header>
  <section class="content-band" id="release-status"><div class="container release-facts"><div><small>Current version</small><strong>{site.version}</strong></div><div><small>Planned support</small><strong>Windows 10 / 11 x64</strong></div><div><small>Verification</small><strong>App and licensing test suites pass</strong></div></div></section>
  <section class="content-band alt"><div class="container content-grid"><h2>Current release status</h2><div class="prose"><p>The internal build has passed installation, launch, bundled FFmpeg, Pro licensing, and cloud AI connection checks. The Microsoft Store package, signed updates, and FFmpeg licensing materials are in final review.</p><p>No public release date has been announced. Checkout will open only after download, activation, updates, and cancellation have been verified end to end.</p></div></div></section>
  <section class="content-band"><div class="container content-grid"><h2>Installation after launch</h2><div class="prose"><ol><li>Download the verified installer from this page.</li><li>Choose optional Explorer integration and file associations.</li><li>Run later installers as in-place updates. Favorites, subtitles, and settings stay in the user data directory.</li></ol><p><a href={withBase("/en/system-requirements/")}>Review system requirements</a></p></div></div></section>
</BaseLayout>
