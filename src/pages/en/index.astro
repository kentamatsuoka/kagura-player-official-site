---
import HeroDemo from "@/components/HeroDemo.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/data/site";

const faqs = [
  { question: "What is Kagura Player?", answer: "Kagura Player is a Windows video player that combines local AI subtitles and translation, A-B clipping, a clip library, and video joining in one workflow." },
  { question: "What can I use now?", answer: "Playback, favorites, folders, A-B repeat, quick A-B clipping, and background export are implemented." },
  { question: "Are AI subtitles and translation available?", answer: "They are implemented. Recognition runs locally, while cloud correction and translation are used only when configured." },
  { question: "How much does Kagura Player cost?", answer: "Free is ¥0. Pro is ¥980 per month or ¥9,800 per year, with a seven-day trial, 30 trial cloud minutes, 600 monthly cloud minutes, and BYOK beyond quota." },
  { question: "Can Kagura Player join multiple clips?", answer: "Yes. Add clips from the library, drag them into order, preview them, and join compatible media into one output." },
];
---

<BaseLayout
  title="Kagura Player - Understand it. Clip it. Make it yours."
  description="Kagura Player combines fast local AI subtitles, translation, A-B clipping, subtitle correction, a clip library, and drag-and-drop video joining for Windows."
  canonicalPath="/en/"
  lang="en"
  faqItems={faqs}
>
  <section class="hero hero-next">
    <canvas class="signal-canvas" data-signal-field aria-hidden="true"></canvas>
    <div class="motion-field" aria-hidden="true"><span></span><span></span><span></span><span></span></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Video player for Windows</p>
        <h1>Kagura Player</h1>
        <p class="hero-promise"><span>Understand it.</span><span>Clip it fast.</span><span>Join the story.</span></p>
        <p class="lead">Show a fast subtitle draft near the playhead, refine the full video in the background, clip the moment, and arrange clips into one video.</p>
        <div class="hero-actions">
          <a class="button primary" href={withBase("/en/download/")}>See Windows release status</a>
          <a class="button secondary" href="#experience">Explore the workflow</a>
        </div>
        <div class="status-rail" aria-label="Feature status">
          <span><b class="status-dot available"></b>Quick clipping available</span>
          <span><b class="status-dot available"></b>Two-pass AI subtitles implemented</span>
          <span><b class="status-dot available"></b>Clip library and joining implemented</span>
        </div>
      </div>
      <HeroDemo lang="en" />
    </div>
  </section>

  <section class="section journey" id="experience">
    <div class="container">
      <div class="section-kicker">ONE FLOW</div>
      <div class="section-head wide-head">
        <h2>From watching to a finished sequence.</h2>
        <p>Stay close to the moment instead of moving between a player, a subtitle tool, and a heavy editor.</p>
      </div>
      <div class="flow-grid">
        <article class="flow-item current"><span class="flow-number">01</span><span class="feature-state ready">AVAILABLE</span><h3>Find it</h3><p>Favorites, folders, and A-B repeat bring the right moment back fast.</p><div class="flow-visual seek-visual" aria-hidden="true"><i></i><i></i><i></i><b>A</b><b>B</b></div></article>
        <article class="flow-item current"><span class="flow-number">02</span><span class="feature-state ready">AVAILABLE</span><h3>Clip it</h3><p>Set A and B, then save in the background while playback continues.</p><div class="flow-visual clip-visual" aria-hidden="true"><span></span><span></span><span></span></div></article>
        <article class="flow-item future"><span class="flow-number">03</span><span class="feature-state ready">AVAILABLE</span><h3>Join it</h3><p>Arrange clips by drag and drop and turn them into one sequence.</p><div class="flow-visual join-visual" aria-hidden="true"><span></span><span></span><span></span><i></i></div></article>
      </div>
    </div>
  </section>

  <section class="section subtitle-lab" id="ai-subtitles">
    <div class="container subtitle-layout">
      <div class="subtitle-copy">
        <div class="section-kicker">AI SUBTITLES / TWO PASSES</div>
        <h2>Understand video sooner.</h2>
        <p class="lead-small">A fast draft appears around the current position first. A high-accuracy model continues over the full video in the background and replaces the draft.</p>
        <ul class="plain-list"><li><span>01</span>Current-position draft first</li><li><span>02</span>High-accuracy full pass in the background</li><li><span>03</span>Edit captions and reuse correction memory</li></ul>
      </div>
      <div class="translation-stage" aria-label="AI subtitle concept preview">
        <div class="translation-head"><span>LIVE CAPTION</span><span class="pulse-label">ANALYZING</span></div>
        <div class="translation-frame"><div class="translation-line line-one"><small>JP</small><span>物語は、ここから始まる。</span></div><div class="translation-line line-two"><small>EN</small><strong>The story starts here.</strong></div><div class="translation-line line-three"><small>CLIP</small><span>Save this moment with subtitles</span></div></div>
        <p>Implemented experience preview. Recognition is local; configured cloud assistance handles context correction and translation.</p>
      </div>
    </div>
  </section>

  <section class="section roadmap" id="roadmap">
    <div class="container roadmap-layout">
      <div><div class="section-kicker">HONEST ROADMAP</div><h2>Available now. Coming next.</h2><p>We label unfinished features clearly and publish them only after implementation and verification.</p></div>
      <div class="roadmap-list">
        <article><span class="feature-state ready">AVAILABLE</span><h3>Playback, favorites, folders, and A-B repeat</h3></article>
        <article><span class="feature-state ready">AVAILABLE</span><h3>Quick A-B clipping and background export</h3></article>
        <article><span class="feature-state ready">IMPLEMENTED</span><h3>Fast draft and high-accuracy full AI subtitles</h3></article>
        <article><span class="feature-state ready">IMPLEMENTED</span><h3>Language detection, translation, subtitle editing, correction memory</h3></article>
        <article><span class="feature-state ready">IMPLEMENTED</span><h3>Pro subtitle burn-in clips, clip library, drag-and-drop joining</h3></article>
        <article><span class="feature-state beta">RELEASE PREP</span><h3>Production licensing, signed updates, and public installer</h3></article>
      </div>
    </div>
  </section>

  <section class="section faq" id="faq">
    <div class="container faq-layout">
      <div><div class="section-kicker">FAQ</div><h2>Questions, answered.</h2></div>
      <div class="faq-list">
        {faqs.map((item, index) => <details open={index === 0}><summary>{item.question}</summary><p>{item.answer}</p></details>)}
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container final-cta-inner">
      <img src={withBase("/media/generated/kagura-player-icon-512.png")} alt="" width="168" height="168" />
      <div><p class="section-kicker">KAGURA PLAYER FOR WINDOWS</p><h2>Do more with the moment you just watched.</h2><p>Understand it with AI subtitles, clip it, and join it without leaving the player workflow.</p><a class="button primary" href={withBase("/en/download/")}>See release status</a></div>
    </div>
  </section>
</BaseLayout>
