---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/data/site";
---

<BaseLayout title="購入完了 - YOMUVIA" description="YOMUVIA Proの購入完了とライセンス有効化。" canonicalPath="/ja/purchase/success/" noindex>
  <header class="page-hero"><div class="container activation-panel"><p class="eyebrow">YOMUVIA PRO</p><h1>7日間のPro体験が<br />始まりました。</h1><p class="lead">下の認証番号をコピーし、YOMUVIAのPro画面へ貼り付けてください。</p><code class="activation-code" data-activation-code>購入情報を確認しています...</code><div class="activation-actions"><button class="button primary" type="button" data-copy-activation disabled>認証番号をコピー</button><a class="button secondary" href={withBase("/ja/help/")}>有効化の手順を見る</a></div><p class="status-callout" data-activation-status>このページは認証が終わるまで閉じないでください。</p></div></header>
  <script>
    const params = new URLSearchParams(window.location.search);
    const sessionId = params.get("session_id")?.trim() ?? "";
    const code = document.querySelector<HTMLElement>("[data-activation-code]");
    const copy = document.querySelector<HTMLButtonElement>("[data-copy-activation]");
    const status = document.querySelector<HTMLElement>("[data-activation-status]");
    if (code && copy && status) {
      if (/^cs_(test_)?[A-Za-z0-9_]+$/.test(sessionId)) {
        code.textContent = sessionId;
        copy.disabled = false;
        status.textContent = "認証番号は購入者本人だけで使用してください。";
        copy.addEventListener("click", async () => {
          await navigator.clipboard.writeText(sessionId);
          copy.textContent = "コピーしました";
        });
      } else {
        code.textContent = "認証番号を取得できませんでした";
        status.textContent = "購入完了メールを確認するか、サポートへ購入時のメールアドレスを添えて連絡してください。";
      }
    }
  </script>
</BaseLayout>
