---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/data/site";
---

<BaseLayout title="ダウンロード - Kagura Player" description="Kagura Player Windows版のダウンロード準備ページです。" canonicalPath="/ja/download/">
  <section class="section">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Download</p>
        <h1>Windows版を準備中。</h1>
        <p class="lead">正式な配布ファイル、バージョン、ファイルサイズ、更新日が確定したら、このページに掲載します。</p>
        <a class="button primary" href={site.downloadUrl}>ダウンロード準備中</a>
      </div>
      <div class="card">
        <h2>公開前に必要な情報</h2>
        <p>対応OS、対応形式、インストール方法、アンインストール方法、既知の問題、プライバシー説明を確定します。</p>
      </div>
    </div>
  </section>
</BaseLayout>
