---
import "../styles/global.css";
import { footerEn, footerJa, localizedRoute, navEn, navJa, site, withBase } from "@/data/site";

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  lang?: "ja" | "en";
  canonicalPath: string;
  breadcrumbTitle?: string;
  faqItems?: FaqItem[];
  noindex?: boolean;
}

const { title, description, lang = "ja", canonicalPath, breadcrumbTitle, faqItems = [], noindex = false } = Astro.props;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION?.trim();
const nav = lang === "ja" ? navJa : navEn;
const footerNav = lang === "ja" ? footerJa : footerEn;
const routePair = localizedRoute(canonicalPath);
const opposite = routePair?.[lang === "ja" ? "en" : "ja"] ?? (lang === "ja" ? "/en/" : "/ja/");
const oppositeLabel = lang === "ja" ? "English" : "日本語";
const absoluteUrl = (path: string) => site.origin ? new URL(withBase(path), `${site.origin}/`).toString() : undefined;
const canonical = absoluteUrl(canonicalPath);
const alternateJa = routePair ? absoluteUrl(routePair.ja) : undefined;
const alternateEn = routePair ? absoluteUrl(routePair.en) : undefined;
const isHome = canonicalPath === "/ja/" || canonicalPath === "/en/";
const resolvedBreadcrumbTitle = breadcrumbTitle ?? title.replace(/\s+-\s+Kagura Player$/, "");
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    ...(isHome ? [{
      "@type": "WebSite",
      "@id": absoluteUrl("/#website"),
      url: absoluteUrl("/"),
      name: site.name,
      alternateName: "Kagura",
      inLanguage: ["ja", "en"]
    }] : []),
    {
      "@type": "SoftwareApplication",
      "@id": absoluteUrl("/#software"),
      name: site.name,
      url: canonical,
      applicationCategory: "MultimediaApplication",
      applicationSubCategory: "Video player and video clipping software",
      operatingSystem: "Windows",
      inLanguage: lang,
      description,
      softwareVersion: site.version,
      featureList: lang === "ja"
        ? ["動画再生", "A-Bリピート", "A-B高速切り抜き", "お気に入りとフォルダ整理", "段階的AI字幕・自動翻訳", "字幕編集学習", "字幕付き切り抜き", "切り抜きライブラリ", "ドラッグ操作対応の動画結合"]
        : ["Video playback", "A-B repeat", "Quick A-B clipping", "Favorites and folders", "Progressive AI subtitles and translation", "Subtitle correction memory", "Clips with burned-in subtitles", "Clip library", "Drag-and-drop video joining"],
      offers: [
        {
          "@type": "Offer",
          name: "Kagura Player Free",
          price: "0",
          priceCurrency: site.proCurrency,
          url: absoluteUrl(lang === "ja" ? "/ja/pricing/" : "/en/pricing/")
        },
        {
          "@type": "Offer",
          name: "Kagura Player Pro Monthly",
          price: site.proPrice,
          priceCurrency: site.proCurrency,
          description: lang === "ja" ? "月600分のクラウド処理と、超過後のBYOKに対応" : "Includes 600 cloud minutes per month, with BYOK beyond the quota",
          priceSpecification: {
            "@type": "UnitPriceSpecification",
            price: site.proPrice,
            priceCurrency: site.proCurrency,
            billingDuration: "P1M"
          },
          url: absoluteUrl(lang === "ja" ? "/ja/pricing/" : "/en/pricing/")
        },
        {
          "@type": "Offer",
          name: "Kagura Player Pro Annual",
          price: site.proAnnualPrice,
          priceCurrency: site.proCurrency,
          priceSpecification: {
            "@type": "UnitPriceSpecification",
            price: site.proAnnualPrice,
            priceCurrency: site.proCurrency,
            billingDuration: "P1Y"
          },
          url: absoluteUrl(lang === "ja" ? "/ja/pricing/" : "/en/pricing/")
        }
      ]
    },
    ...(!isHome && canonical ? [{
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: lang === "ja" ? "ホーム" : "Home",
          item: absoluteUrl(lang === "ja" ? "/ja/" : "/en/")
        },
        {
          "@type": "ListItem",
          position: 2,
          name: resolvedBreadcrumbTitle,
          item: canonical
        }
      ]
    }] : []),
    ...(faqItems.length > 0 ? [{
      "@type": "FAQPage",
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer
        }
      }))
    }] : [])
  ]
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    <meta name="robots" content={noindex ? "noindex,nofollow,noarchive" : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"} />
    {canonical && <link rel="canonical" href={canonical} />}
    {alternateJa && <link rel="alternate" hreflang="ja" href={alternateJa} />}
    {alternateEn && <link rel="alternate" hreflang="en" href={alternateEn} />}
    {routePair && <link rel="alternate" hreflang="x-default" href={alternateJa} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={lang === "ja" ? "ja_JP" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "ja" ? "en_US" : "ja_JP"} />
    {site.origin && <meta property="og:image" content={absoluteUrl("/og.png")} />}
    {site.origin && <meta property="og:image:width" content="1729" />}
    {site.origin && <meta property="og:image:height" content="910" />}
    {site.origin && <meta property="og:image:alt" content={lang === "ja" ? "Kagura Player - AI字幕でわかる。A-B指定ですぐ切れる。" : "Kagura Player - Understand with AI subtitles. Clip with A-B."} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {site.origin && <meta name="twitter:image" content={absoluteUrl("/og.png")} />}
    <link rel="icon" type="image/png" href={withBase("/media/generated/kagura-player-context-menu-32.png")} />
    <meta name="theme-color" content="#07080d" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script is:inline>document.documentElement.dataset.motion = "on";</script>
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === "ja" ? "本文へ移動" : "Skip to content"}</a>
    <div class="scroll-progress" data-scroll-progress aria-hidden="true"></div>
    <div class="pointer-aura" data-pointer-aura aria-hidden="true"></div>
    <div class="site-shell">
      <header class="site-header">
        <div class="container header-inner">
          <a class="brand" href={withBase(lang === "ja" ? "/ja/" : "/en/")} aria-label={site.name}>
            <img class="brand-mark" src={withBase("/media/generated/kagura-player-context-menu-32.png")} width="32" height="32" alt="" aria-hidden="true" />
            <span>{site.name}</span>
          </a>
          <nav class="nav" aria-label={lang === "ja" ? "主要ナビゲーション" : "Main navigation"}>
            {nav.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
          </nav>
          <div class="header-actions">
            <a class="lang-link" href={withBase(opposite)} data-language-choice={lang === "ja" ? "en" : "ja"}>{oppositeLabel}</a>
            <a class="button primary" href={withBase(lang === "ja" ? "/ja/download/" : "/en/download/")}>
              {lang === "ja" ? "ダウンロード" : "Download"}
            </a>
          </div>
        </div>
      </header>
      <main id="main">
        <slot />
      </main>
      <footer class="footer">
        <div class="container footer-grid">
          <div class="footer-brand">
            <img src={withBase("/media/generated/kagura-player-context-menu-32.png")} width="32" height="32" alt="" />
            <div><strong>{site.name}</strong><span>{site.version} / Windows</span></div>
          </div>
          <nav class="footer-nav" aria-label={lang === "ja" ? "フッターナビゲーション" : "Footer navigation"}>
            {footerNav.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
          </nav>
          <p class="footer-note">{lang === "ja" ? "手元の動画を、理解して、切り抜いて、つなげる。" : "Understand, clip, and join the videos on your PC."}</p>
        </div>
      </footer>
    </div>
    <script is:inline>
      try {
        const languageKey = "kagura-language";
        const savedLanguage = localStorage.getItem(languageKey);
        const validLanguage = savedLanguage === "ja" || savedLanguage === "en" ? savedLanguage : null;
        if (location.pathname.endsWith("/ja/") && !validLanguage && !navigator.language.toLowerCase().startsWith("ja")) {
          location.replace(location.pathname.replace(/\/ja\/$/, "/en/"));
        }
        document.querySelectorAll("[data-language-choice]").forEach((link) => {
          link.addEventListener("click", () => {
            const choice = link.getAttribute("data-language-choice");
            if (choice === "ja" || choice === "en") localStorage.setItem(languageKey, choice);
          });
        });
      } catch {
        // Japanese remains the fallback when browser language storage is unavailable.
      }

      const motionEnabled = true;
      const aura = document.querySelector("[data-pointer-aura]");
      const updateProgress = () => {
        const travel = document.documentElement.scrollHeight - window.innerHeight;
        const ratio = travel > 0 ? window.scrollY / travel : 0;
        document.documentElement.style.setProperty("--scroll-progress", String(ratio));
      };
      updateProgress();
      window.addEventListener("scroll", updateProgress, { passive: true });

      if (motionEnabled) {
        const revealTargets = document.querySelectorAll(".section .container, .flow-item, .use-grid article, .roadmap-list article");
        revealTargets.forEach((element) => element.classList.add("reveal-ready"));
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-revealed");
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12 });
        revealTargets.forEach((element) => observer.observe(element));

        if (aura instanceof HTMLElement && matchMedia("(pointer: fine)").matches) {
          window.addEventListener("pointermove", (event) => {
            aura.style.setProperty("--pointer-x", `${event.clientX}px`);
            aura.style.setProperty("--pointer-y", `${event.clientY}px`);
            aura.classList.add("is-active");
          }, { passive: true });
        }

        const canvas = document.querySelector("[data-signal-field]");
        if (canvas instanceof HTMLCanvasElement) {
          const context = canvas.getContext("2d");
          const compact = window.innerWidth < 600;
          const points = Array.from({ length: compact ? 24 : 52 }, (_, index) => ({
            x: Math.random(), y: Math.random(),
            vx: (Math.random() - 0.5) * 0.0002,
            vy: (Math.random() - 0.5) * 0.00015,
            phase: index * 0.71
          }));
          const streaks = Array.from({ length: compact ? 2 : 5 }, (_, index) => ({
            offset: index / (compact ? 2 : 5),
            speed: 0.000055 + index * 0.000008,
            y: 0.12 + Math.random() * 0.7
          }));
          const resizeCanvas = () => {
            if (!context) return;
            const ratio = Math.min(window.devicePixelRatio || 1, 1.5);
            canvas.width = Math.floor(canvas.clientWidth * ratio);
            canvas.height = Math.floor(canvas.clientHeight * ratio);
            context.setTransform(ratio, 0, 0, ratio, 0, 0);
          };
          const drawField = (time) => {
            if (!context) return;
            const width = canvas.clientWidth;
            const height = canvas.clientHeight;
            context.clearRect(0, 0, width, height);
            points.forEach((point, index) => {
              point.x = (point.x + point.vx + 1) % 1;
              point.y = (point.y + point.vy + 1) % 1;
              const x = point.x * width;
              const y = point.y * height;
              const glow = 0.38 + Math.sin(time * 0.001 + point.phase) * 0.24;
              context.fillStyle = index % 3 === 0 ? `rgba(118,244,255,${glow})` : `rgba(166,126,255,${glow})`;
              context.beginPath();
              context.arc(x, y, index % 5 === 0 ? 2.1 : 1.1, 0, Math.PI * 2);
              context.fill();
              for (let next = index + 1; next < points.length; next += 1) {
                const other = points[next];
                const ox = other.x * width;
                const oy = other.y * height;
                const distance = Math.hypot(x - ox, y - oy);
                if (distance < 135) {
                  context.strokeStyle = `rgba(132,172,255,${0.12 * (1 - distance / 135)})`;
                  context.lineWidth = 1;
                  context.beginPath();
                  context.moveTo(x, y);
                  context.lineTo(ox, oy);
                  context.stroke();
                }
              }
            });
            streaks.forEach((streak) => {
              const x = ((time * streak.speed + streak.offset) % 1.35 - 0.18) * width;
              const y = streak.y * height;
              const gradient = context.createLinearGradient(x - 160, y + 70, x, y);
              gradient.addColorStop(0, "rgba(118,244,255,0)");
              gradient.addColorStop(1, "rgba(241,183,255,0.8)");
              context.strokeStyle = gradient;
              context.lineWidth = 1.5;
              context.beginPath();
              context.moveTo(x - 160, y + 70);
              context.lineTo(x, y);
              context.stroke();
            });
            requestAnimationFrame(drawField);
          };
          resizeCanvas();
          window.addEventListener("resize", resizeCanvas, { passive: true });
          requestAnimationFrame(drawField);
        }
      }
    </script>
  </body>
</html>
