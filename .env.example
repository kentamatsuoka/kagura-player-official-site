# Production defaults target the repository's GitHub Pages project site.
# Set both values only when deploying to a custom origin or path.
PUBLIC_SITE_ORIGIN=https://kentamatsuoka.github.io
PUBLIC_BASE_PATH=/kagura-player-official-site

# Paste only the verification token from Google Search Console, not the whole meta tag.
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Keep these empty until the exact public artifact, Stripe checkout, and support endpoint are verified.
PUBLIC_DOWNLOAD_URL=
PUBLIC_CHECKOUT_URL=
PUBLIC_MONTHLY_CHECKOUT_URL=
PUBLIC_ANNUAL_CHECKOUT_URL=
PUBLIC_PRO_PRICE=1480
PUBLIC_PRO_CURRENCY=JPY
PUBLIC_SUPPORT_URL=
